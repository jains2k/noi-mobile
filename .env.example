# Backend URL (your deployed Koyeb app)
EXPO_PUBLIC_BASE_URL=https://your-app.koyeb.app
EXPO_PUBLIC_PROXY_BASE_URL=https://your-app.koyeb.app

# App identifier — used as SecureStore key prefix, can be any stable string
EXPO_PUBLIC_PROJECT_GROUP_ID=noi-app

# App URL for OAuth redirects (used in AuthWebView)
EXPO_PUBLIC_APP_URL=https://your-app.koyeb.app
